# Trading 212 environment: demo or live.
STATOS_TRADING212_ENV=demo

# Optional explicit base URL. Normally leave blank and use STATOS_TRADING212_ENV.
# STATOS_TRADING212_BASE_URL=https://demo.trading212.com/api/v0

# Required for live Trading 212 refreshes. Leave blank to use sample data.
TRADING212_API_KEY=
TRADING212_API_SECRET=

# cache or yahoo. Yahoo is unofficial and should be treated as replaceable enrichment.
STATOS_ENRICHMENT_PROVIDER=cache

# Optional delay between enrichment lookups, e.g. 500ms or 2s.
STATOS_ENRICHMENT_DELAY=

# Set to 1 to force embedded sample data.
STATOS_SAMPLE=0
